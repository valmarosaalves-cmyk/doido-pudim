import flixel.math.FlxMath;
import states.PlayState;

var daOffset:Array<Array<Float>> = [
    [0,0,0,0],
    [0,0,0,0]
];

function update(elapsed:Float)
{
    var i:Int = 0;
    for(strumline in playField.strumlines)
    {
        for(strum in strumline.strums)
        {
            strum.y = FlxMath.lerp(
                strum.y,
                strum.initialPos.y + daOffset[i][strum.lane] * (strumline.downscroll ? 1 : -1),
                elapsed * 20
            );
            daOffset[i][strum.lane] = FlxMath.lerp(daOffset[i][strum.lane], 0.0, elapsed * 8);
        }
        i++;
    }
}

function onNoteHit(note, strumline)
{
    if (!note.isHold)
        daOffset[strumline.isPlayer ? 1 : 0][note.data.lane] = 20;
}

function onNoteHold(note, strumline)
{
    daOffset[strumline.isPlayer ? 1 : 0][note.data.lane] = (PlayState.instance.curStep % 2 == 0 ? 20 : 10);
}