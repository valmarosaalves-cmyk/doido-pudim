function create()
{
    camZoom = 1;
    gfPos = {x: 660 + 20, y: 580 + 50};
    dadPos = {x: 260 + 50, y: 700};
    bfPos = {x: 1100 - 70, y: 700};

    var bg:FlxSprite = new FlxSprite(400, 100);
    bg.frames = Assets.sparrow('stages/school/animatedEvilSchool');
    bg.animation.addByPrefix('idle', 'background 2', 24);
    bg.animation.play('idle');
    bg.scrollFactor.set(0.8, 0.9);
    bg.antialiasing = false;
    bg.scale.set(6,6);
    add(bg);
}